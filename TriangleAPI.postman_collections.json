{
  "info": {
    "_postman_id": "triangle-api-testing",
    "name": "Triangle API Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Triangles",
      "request": {
        "method": "GET",
        "url": "{{url}}/triangles"
      }
    },
    {
      "name": "Get Triangle by ID",
      "request": {
        "method": "GET",
        "url": "{{url}}/triangles/1"
      }
    },
    {
      "name": "Get Triangle by Invalid ID",
      "request": {
        "method": "GET",
        "url": "{{url}}/triangles/999"
      }
    },
    {
      "name": "Create Valid Triangle - Scalene",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"a\": 3,\n  \"b\": 4,\n  \"c\": 5\n}"
        },
        "url": "{{url}}/triangles"
      }
    },
    {
      "name": "Create Valid Triangle - Equilateral",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"a\": 6,\n  \"b\": 6,\n  \"c\": 6\n}"
        },
        "url": "{{url}}/triangles"
      }
    },
    {
      "name": "Create Valid Triangle - Isosceles",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"a\": 5,\n  \"b\": 5,\n  \"c\": 8\n}"
        },
        "url": "{{url}}/triangles"
      }
    },
    {
      "name": "Create Invalid Triangle - Zero Side",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"a\": 0,\n  \"b\": 4,\n  \"c\": 5\n}"
        },
        "url": "{{url}}/triangles"
      }
    },
    {
      "name": "Create Invalid Triangle - Negative Side",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"a\": -3,\n  \"b\": 4,\n  \"c\": 5\n}"
        },
        "url": "{{url}}/triangles"
      }
    },
    {
      "name": "Create Invalid Triangle - Not a Triangle",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"a\": 1,\n  \"b\": 2,\n  \"c\": 10\n}"
        },
        "url": "{{url}}/triangles"
      }
    },
    {
      "name": "Create Invalid Triangle - Missing Value",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"a\": 3,\n  \"b\": 4\n}"
        },
        "url": "{{url}}/triangles"
      }
    }
  ]
}